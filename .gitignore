# OS / editor
.DS_Store
.idea/
.vscode/

# Python
__pycache__/
*.py[cod]
*.pyd
.python-version
.venv/
venv/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Local environment / logs
.env
.env.local
*.log

# Build / packaging
build/
dist/
*.egg-info/

# Node / satvis source worktrees if used locally
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Satvis: the built dist/ in static/satvis/ IS tracked.
# Only ignore source maps and seeded TLE data.
static/satvis/**/*.map

# Seeded TLE group data is deployment/runtime data, not source.
static/satvis/data/tle/groups/*.txt
