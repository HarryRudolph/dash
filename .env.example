# Core app
DASHBOARD_DEV=0
DASHBOARD_OFFLINE_MODE=1

# Sensor
SENSOR_NAME=Sensor Alpha
SENSOR_LAT=51.5074
SENSOR_LON=-0.1278

# Satvis imagery
# Leave TILE_SERVER_URL empty to use the bundled OfflineHighres imagery.
TILE_SERVER_URL=
TILE_SERVER_CREDIT=
TILE_SERVER_MAX_ZOOM=18

# Senzing
# Set these when the vessel network explorer should connect to your internal SZ API.
SZ_API_URL=
SZ_DATA_SOURCE=AIS
SZ_API_TOKEN=
SZ_TIMEOUT_SECONDS=10

# Override these only if your SZ gateway exposes different REST paths.
SZ_ENTITY_BY_RECORD_PATH=/entity-resolution/v1/entities/by-record/{data_source}/{record_id}
SZ_ENTITY_BY_ENTITY_PATH=/entity-resolution/v1/entities/{entity_id}
