# Core app
DASHBOARD_DEV=0
DASHBOARD_OFFLINE_MODE=1
FORWARDED_HOST=http://localhost:8000

# Sensor
SENSOR_NAME=Sensor Alpha
SENSOR_LAT=51.5074
SENSOR_LON=-0.1278

# Elasticsearch
ES_URL=
ES_AIS_INDEX=ais_positions
ES_OWNERSHIP_INDEX=vessel_ownership
ES_USER=
ES_PASS=

# MongoDB
MONGO_URL=
MONGO_DATABASE=analytics

# MinIO
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_SECURE=1

# PostgreSQL
POSTGRES_DSN=

# Satvis
# Comma-separated Satvis tag names to enable by default (e.g. Resource,Science).
# Available tags depend on the TLE groups downloaded: Resource, Weather, Science,
# Stations, Starlink, GNSS, Cubesat, etc.
SATVIS_DEFAULT_TAGS=Resource

# Tile server — slippy map format: {z}/{y}/{x}
# Leave TILE_SERVER_URL empty to use the bundled OfflineHighres imagery.
TILE_SERVER_URL=
TILE_SERVER_CREDIT=
TILE_SERVER_MAX_ZOOM=18

# Senzing
# Set these when the vessel network explorer should connect to your internal SZ API.
SZ_API_URL=
SZ_DATA_SOURCE=AIS
SZ_API_TOKEN=
SZ_TIMEOUT_SECONDS=10

# Override these only if your SZ gateway exposes different REST paths.
SZ_ENTITY_BY_RECORD_PATH=/entity-resolution/v1/entities/by-record/{data_source}/{record_id}
SZ_ENTITY_BY_ENTITY_PATH=/entity-resolution/v1/entities/{entity_id}
